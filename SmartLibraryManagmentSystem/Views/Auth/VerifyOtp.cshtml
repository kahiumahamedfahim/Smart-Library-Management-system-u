@using SmartLibraryManagmentSystem.ViewModels.Authentication
@model VerifyOtpViewModel

<div class="container mt-5">
    <div class="col-md-6 mx-auto">
        <div class="card p-4 shadow">
            <h3 class="text-center mb-4">Verify OTP</h3>

            <form asp-action="VerifyOtp" method="post">

                <div asp-validation-summary="All" class="text-danger"></div>

                <input type="hidden" asp-for="Email" />

                <div class="mb-3">
                    <label asp-for="OtpCode" class="form-label"></label>
                    <input asp-for="OtpCode" class="form-control" />
                    <span asp-validation-for="OtpCode" class="text-danger"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success">
                        Verify
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}